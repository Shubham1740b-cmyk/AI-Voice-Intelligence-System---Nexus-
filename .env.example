# J.A.R.V.I.S — Environment Configuration
# Copy to .env and fill in your keys:
#   cp .env.example .env

# ── OpenRouter (Primary LLM Brain) ────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── WolframAlpha (Math & Science) ─────────────────────────────────
# Get your App ID at: https://developer.wolframalpha.com
WOLFRAM_APP_ID=XXXXXX-XXXXXXXXXX

# ── OpenWeatherMap (Live Weather) ─────────────────────────────────
# Get your key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-api-key

# ── Server (local WebSocket mode only) ────────────────────────────
JARVIS_HOST=localhost
JARVIS_PORT=8765
JARVIS_DEBUG=false
JARVIS_DEMO_MODE=false

# ── Default city for weather queries ──────────────────────────────
JARVIS_CITY=New York
